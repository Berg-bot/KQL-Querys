##Correlate file seen on device with email attachment (phishing dropper detection)


// join DeviceFileEvents (files created/executed) to EmailAttachmentInfo by SHA256
let window = 7d;
DeviceFileEvents
| where Timestamp >= ago(window)
| where tolower(FileName) has_any ("teamviewer","anydesk","screenconnect","logmein","rustdesk")
| project FileSha256 = SHA256, DeviceFile_Timestamp = Timestamp, DeviceName, AccountName, FileName, FolderPath, ReportId
| join kind=inner (
    EmailAttachmentInfo
    | where Timestamp >= ago(window)
    | project EmailSha256 = SHA256, Email_Timestamp = Timestamp, NetworkMessageId, SenderFromAddress, RecipientEmailAddress, FileName, ThreatTypes, ThreatNames
) on $left.FileSha256 == $right.EmailSha256
| extend TimeDelta_minutes = datetime_diff("minute", DeviceFile_Timestamp, Email_Timestamp)
| project DeviceName, DeviceFile_Timestamp, FileName = FileName, FolderPath, NetworkMessageId, SenderFromAddress, RecipientEmailAddress, ThreatTypes, ThreatNames, TimeDelta_minutes
| order by DeviceFile_Timestamp desc

