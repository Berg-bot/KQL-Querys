##Suspicious parent/launcher (spawned by email clients, archive tools, or scripts)

let suspiciousParents = dynamic(["outlook.exe","word.exe","excel.exe","winword.exe","powershell.exe","cmd.exe","rundll32.exe","wscript.exe","winrar.exe","7zfm.exe"]);
DeviceEvents
| where tolower(InitiatingProcessParentFileName) in (suspiciousParents)
| where tolower(FileName) has_any ("teamviewer","anydesk","screenconnect","logmein","rustdesk")
| project Timestamp, DeviceName, AccountName, FileName, FolderPath, SHA1, InitiatingProcessFileName, InitiatingProcessParentFileName, InitiatingProcessCommandLine, ProcessCreationTime, ReportId
| order by Timestamp desc
